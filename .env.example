# Core app
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIMEZONE=America/Argentina/Buenos_Aires
SESSION_SECRET=replace-with-a-long-random-secret
PASSWORD_SALT_ROUNDS=12

# Supabase / persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
ALLOW_LOCALDB_IN_PRODUCTION=false
ALLOW_INSECURE_SESSION_SECRET=false
ALLOW_TEST_LOGIN=false
LOCALDB_FILE=.localdb.json
LOCALDB_PERSISTENCE=true
LOCALDB_ENABLE_PERSISTENCE=false

# Public URL fallbacks
NEXT_PUBLIC_CONFIRMATION_URL=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_PUBLIC_URL=
APP_URL=
SITE_URL=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_DEFAULT_COUNTRY_CODE=54
TWILIO_NOTIFY_TO=
TWILIO_WHATSAPP_TEMPLATE_CONFIRMATION=

# ARCA/AFIP invoicing
AFIP_FACTURACION_ACTIVA=false
AFIP_PRODUCCION=false
AFIP_CUIT=
AFIP_PUNTO_VENTA=1
AFIP_CBTE_TIPO=6
AFIP_ACCESS_TOKEN=
AFIP_CERT_PATH=certs/afip/cert.crt
AFIP_KEY_PATH=certs/afip/key.pem
AFIP_CERT=
AFIP_KEY=
AFIP_CERT_BASE64=
AFIP_KEY_BASE64=
AFIP_IVA_ID=5
AFIP_IVA_PORCENTAJE=21

# Branding and templates
FACTURA_LOGO_PATH=
FACTURA_LOGO_DATA=
FACTURA_LEYENDA=
FACTURA_LEYENDA_FOOTER=
FACTURA_EMISOR_NOMBRE=
FACTURA_EMISOR_DOMICILIO=
FACTURA_EMISOR_TELEFONO=
FACTURA_EMISOR_EMAIL=
GIFTCARD_TEMPLATE_PATH=
GIFTCARD_TEMPLATE_DATA=

# Storage buckets
SUPABASE_STORAGE_BUCKET_FACTURAS=facturas
SUPABASE_STORAGE_BUCKET_GIFTCARDS=giftcards
SUPABASE_STORAGE_BUCKET_SHARE_FILES=share-files
SUPABASE_STORAGE_BUCKET_TURNOS_FOTOS=turnos-fotos

# Scheduled jobs / report tuning
CRON_SECRET=
CONFIRMATION_TOKEN_TTL_HOURS=48
DECLARACION_JURADA_LINK_TTL_HOURS=24
SHARE_LINK_TTL_DAYS=7
REPORTES_SERVICIO_VENCIDO_DIAS=30
STORAGE_MIGRATION_BATCH_SIZE=100
STORAGE_CLEANUP_BATCH_SIZE=100
FACTURAS_STORAGE_RETENTION_DAYS=3650
GIFTCARDS_STORAGE_RETENTION_DAYS=3650
